{
  email {$ACME_EMAIL}
}

claudecommunity.com {
  redir https://www.claudecommunity.com{uri} permanent
}

www.claudecommunity.com {
  encode zstd gzip

  @stats_dashboard path /stats /stats/
  redir @stats_dashboard https://stats.claudecommunity.com/ permanent

  handle_path /stats/* {
    reverse_proxy umami:3000
  }

  handle {
    reverse_proxy app:3000
  }

  header {
    -Server
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    Referrer-Policy strict-origin-when-cross-origin
    Permissions-Policy "camera=(), microphone=(), geolocation=()"
  }
}

stats.claudecommunity.com {
  encode zstd gzip
  reverse_proxy umami:3000

  header {
    -Server
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    Referrer-Policy strict-origin-when-cross-origin
    Permissions-Policy "camera=(), microphone=(), geolocation=()"
  }
}

admin.claudecommunity.com {
  encode zstd gzip

  basic_auth {
    admin {$ADMIN_PASSWORD_HASH}
  }

  @root path /
  redir @root /admin/subscribers permanent
  reverse_proxy app:3000

  header {
    -Server
    X-Content-Type-Options nosniff
    X-Frame-Options DENY
    Referrer-Policy no-referrer
    Permissions-Policy "camera=(), microphone=(), geolocation=()"
    X-Robots-Tag "noindex, nofollow, noarchive"
    Cache-Control "no-store"
  }
}
