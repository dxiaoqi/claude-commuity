{
  email {$ACME_EMAIL}
}

claudecommunity.com {
  redir https://www.claudecommunity.com{uri} permanent
}

www.claudecommunity.com {
  encode zstd gzip

  @stats_dashboard path /stats /stats/
  redir @stats_dashboard https://stats.claudecommunity.com/ permanent

  handle_path /stats/* {
    reverse_proxy umami:3000
  }

  handle {
    reverse_proxy app:3000
  }

  header {
    -Server
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    Referrer-Policy strict-origin-when-cross-origin
    Permissions-Policy "camera=(), microphone=(), geolocation=()"
  }
}

stats.claudecommunity.com {
  encode zstd gzip
  reverse_proxy umami:3000

  header {
    -Server
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    Referrer-Policy strict-origin-when-cross-origin
    Permissions-Policy "camera=(), microphone=(), geolocation=()"
  }
}
